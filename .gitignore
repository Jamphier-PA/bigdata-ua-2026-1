# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/

# ── Jupyter Notebooks ─────────────────────────────────────────
.ipynb_checkpoints/
*-checkpoint.ipynb

# ── Entornos virtuales ────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
bigdata-ua/

# ── Datos sensibles ───────────────────────────────────────────
.env
*.env
secrets.py
config_local.py
credentials.json
*_key.json
*.pem
*.key

# ── Datasets grandes (subir links, no archivos) ───────────────
*.csv.gz
*.parquet
*.avro
*.orc
datasets/raw/
# Excepción: datasets pequeños para demos sí se suben
!datasets/*.csv
!semana_*/datasets/*.csv
!semana_*/datasets/*.json

# ── Spark ─────────────────────────────────────────────────────
derby.log
metastore_db/
spark-warehouse/

# ── MacOS ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Windows ───────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── IDEs ──────────────────────────────────────────────────────
.idea/
.vscode/settings.json
*.swp
*.swo
.project
.classpath

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── Docker ────────────────────────────────────────────────────
.docker/

# ── Hadoop config local (no subir al repo) ────────────────────
hadoop_config/

# ── Outputs de PowerPoint y Word (demasiado pesados) ─────────
*.pptx
*.docx
# Excepción: si el docente necesita subir slides
!semana_*/slides/*.pptx
